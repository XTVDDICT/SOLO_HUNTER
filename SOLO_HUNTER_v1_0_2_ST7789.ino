void handleStatusJson() {
  String json = "{";
  json += "\"ip\":\"" + currentIpText() + "\",";
  json += "\"status\":\"" + statusText + "\",";
  json += "\"balance_dgb\":" + String(balanceDGB, 8) + ",";
  json += "\"dgb_usd\":" + String(dgbPriceUsd, 8) + ",";
  json += "\"wallet_usd\":" + String(walletUsdValue, 8) + ",";
  json += "\"flip\":" + String(cfgFlip ? "true" : "false");
  json += "}";
  server.send(200, "application/json", json);
}

void setupWebServer() {
  server.on("/", HTTP_GET, handleRoot);
  server.on("/save", HTTP_POST, handleSave);
  server.on("/wifi", HTTP_POST, handleOpenWifiPortal);
  server.on("/status", HTTP_GET, handleStatusJson);
  server.on("/clearblock", HTTP_POST, handleClearBlockPopup);
  server.begin();
}

void runWifiManagerPortal() {
  WiFiManager wm;
  drawStaticLayout();
  statusText = "OPEN SETUP AP";
  drawValues();
  wm.setConfigPortalTimeout(180);
  bool connected = wm.autoConnect(AP_SSID, AP_PASS);

  if (!connected) {
    statusText = "WIFI PORTAL TIMEOUT";
    drawValues();
    return;
  }

  statusText = "WIFI CONNECTED";
  drawValues();
  portalMode = false;
}

void setup() {
  pinMode(TFT_BL, OUTPUT);
  digitalWrite(TFT_BL, HIGH);

  pinMode(REAR_LED, OUTPUT);
  rearLedOn();

  tft.init();
  loadPrefs();
  applyRotation();
  tft.setTextDatum(top_left);
  tft.fillScreen(C_BG);

  drawStaticLayout();
  statusText = "STARTING WIFI...";
  drawValues();

  if (WiFi.status() != WL_CONNECTED) {
    runWifiManagerPortal();
  }

  setupWebServer();

  if (WiFi.status() == WL_CONNECTED) {
    refreshWalletOnly();
    refreshUsdOnly();
  }

  drawStaticLayout();
  drawValues();

  if (blockPopupLatched) {
    popupActive = true;
    popupUntil = 0;
    drawBlockPopup();
  } else if (testPopupRequested) {
    popupDeltaDGB = 0.00f;
    blockPopupLatched = false;
    popupActive = true;
    popupUntil = millis() + TEST_POPUP_MS;
    drawBlockPopup();
    testPopupRequested = false;
    savePrefs();
  } else if (popupActive && millis() < popupUntil) {
    drawBlockPopup();
  }

  lastWalletFetch = millis();
  lastUsdFetch = millis();
}

void loop() {
  rearLedOn();
  server.handleClient();

  if (portalMode) {
    runWifiManagerPortal();
    drawStaticLayout();
    drawValues();
  }

  if (WiFi.status() != WL_CONNECTED) {
    delay(100);
    return;
  }

  // POPUP LOCK: freeze background updates while popup is active
  if (popupActive) {
    if (blockPopupLatched) {
      delay(20);
      return;
    }
    if (millis() >= popupUntil) {
      popupActive = false;
      drawStaticLayout();
      drawValues();
    } else {
      delay(20);
      return;
    }
  }

  if (millis() - lastWalletFetch >= WALLET_REFRESH_MS) {
    lastWalletFetch = millis();
    refreshWalletOnly();
    drawValues();
  }

  uint32_t usdInterval = haveUsdData ? USD_REFRESH_MS : USD_RETRY_FAST_MS;
  if (millis() - lastUsdFetch >= usdInterval) {
    lastUsdFetch = millis();
    refreshUsdOnly();
    drawValues();
  }

  delay(20);
}
