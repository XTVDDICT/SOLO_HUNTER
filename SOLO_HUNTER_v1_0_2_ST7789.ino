void rearLedOn() {
  digitalWrite(REAR_LED, LOW);
}

String fmt2(float v) {
  char buf[24];
  dtostrf(v, 0, 2, buf);
  return String(buf);
}

void trimConfig() {
  cfgWallet.trim();
}

void savePrefs() {
  trimConfig();
  prefs.begin("solo", false);
  prefs.putString("wallet", cfgWallet);
  prefs.putBool("flip", cfgFlip);
  prefs.putBool("testpop", testPopupRequested);
  prefs.putFloat("lastbal", lastBalanceDGB);
  prefs.putFloat("lastusd", dgbPriceUsd);
  prefs.putBool("blocklat", blockPopupLatched);
  prefs.putFloat("popupdgb", popupDeltaDGB);
  prefs.end();
}

void loadPrefs() {
  prefs.begin("solo", true);
  cfgWallet = prefs.getString("wallet", "");
  cfgFlip = prefs.getBool("flip", false);
  testPopupRequested = prefs.getBool("testpop", false);
  lastBalanceDGB = prefs.getFloat("lastbal", -1.0f);
  dgbPriceUsd = prefs.getFloat("lastusd", 0.0f);
  blockPopupLatched = prefs.getBool("blocklat", false);
  popupDeltaDGB = prefs.getFloat("popupdgb", 0.0f);
  prefs.end();
  trimConfig();
  haveUsdData = (dgbPriceUsd > 0.0f);
}

void saveLastBalance() {
  prefs.begin("solo", false);
  prefs.putFloat("lastbal", lastBalanceDGB);
  prefs.end();
}

void saveLastUsd() {
  prefs.begin("solo", false);
  prefs.putFloat("lastusd", dgbPriceUsd);
  prefs.end();
}

void savePopupState() {
  prefs.begin("solo", false);
  prefs.putBool("blocklat", blockPopupLatched);
  prefs.putFloat("popupdgb", popupDeltaDGB);
  prefs.end();
}

void clearLatchedBlockPopup() {
  blockPopupLatched = false;
  popupActive = false;
  popupUntil = 0;
  popupDeltaDGB = 0.0f;
  savePopupState();
  drawStaticLayout();
  drawValues();
}

void applyRotation() {
  tft.setRotation(cfgFlip ? 3 : 1);
}

String currentIpText() {
  if (WiFi.status() == WL_CONNECTED) return WiFi.localIP().toString();
  return "NO WIFI";
}

String htmlEscape(String s) {
  s.replace("&", "&amp;");
  s.replace("<", "&lt;");
  s.replace(">", "&gt;");
  s.replace("\"", "&quot;");
  return s;
}

void drawBorder() {
  tft.drawRect(0, 0, 320, 240, C_GREEN);
  tft.drawRect(1, 1, 318, 238, C_GREEN);
  tft.drawRect(2, 2, 316, 236, C_GREEN2);
  tft.drawRect(3, 3, 314, 234, C_GREEN2);
}

void drawStaticLayout() {
  tft.fillScreen(C_BG);
  drawBorder();

  tft.setTextColor(C_GREEN, C_BG);
  tft.setTextSize(2);
  tft.setCursor(74, 10);
  tft.print("__SOLO_HUNTER__");

  int imgX = (320 - IMG_W) / 2;
  int imgY = 34;
  tft.setSwapBytes(true);
  tft.pushImage(imgX, imgY, IMG_W, IMG_H, acceptedImg);
  tft.setSwapBytes(false);

  tft.drawFastHLine(20, 180, 280, C_GREEN2);
  tft.drawFastHLine(20, 222, 280, C_GREEN2);

  tft.setTextSize(1);
  tft.setTextColor(C_DIM, C_BG);
  tft.setCursor(24, 186);
  tft.print("DGB BAL");
  tft.setCursor(250, 186);
  tft.print("USD");
  tft.setCursor(24, 226);
  tft.print("STATUS");
}

void drawValues() {
  tft.fillRect(20, 194, 280, 24, C_BG);
  tft.setTextSize(2);

  if (haveWalletData) {
    tft.setTextColor(C_GREEN, C_BG);
    tft.setCursor(24, 196);
    tft.print(fmt2(balanceDGB));

    tft.fillRect(210, 194, 90, 24, C_BG);
    if (haveUsdData) {
      walletUsdValue = balanceDGB * dgbPriceUsd;
      tft.setTextColor(C_GREEN, C_BG);
      tft.setTextDatum(top_right);
      tft.drawString("$" + fmt2(walletUsdValue), 296, 196);
      tft.setTextDatum(top_left);
    } else {
      tft.setTextColor(C_WARN, C_BG);
      tft.setTextSize(1);
      tft.setTextDatum(top_right);
      tft.drawString("WAIT", 296, 200);
      tft.setTextDatum(top_left);
      tft.setTextSize(2);
    }
  } else {
    tft.setTextColor(C_WARN, C_BG);
    tft.setCursor(24, 196);
    tft.print("NO DATA");
  }

  tft.fillRect(78, 224, 222, 12, C_BG);
  tft.setTextSize(1);
  tft.setTextColor(statusText.startsWith("LIVE") ? C_GREEN : C_ALERT, C_BG);
  tft.setCursor(78, 226);
  tft.print(statusText);
}

void drawBlockPopup() {
  if (!popupActive) return;
  if (!blockPopupLatched && millis() >= popupUntil) return;

  // Bigger centered card
  int w = 240;
  int h = 90;
  int x = (320 - w) / 2;
  int y = (240 - h) / 2;

  tft.fillRoundRect(x, y, w, h, 12, C_POPBG);
  tft.drawRoundRect(x, y, w, h, 12, C_GREEN);
  tft.drawRoundRect(x+1, y+1, w-2, h-2, 12, C_GREEN2);

  // Title
  tft.setTextColor(C_WARN, C_POPBG);
  tft.setTextSize(2);
  tft.setCursor(x + 40, y + 15);
  tft.print("BLOCK FOUND");

  // Amount (supports large rewards)
  tft.setTextColor(C_GREEN, C_POPBG);
  tft.setTextSize(2);

  String reward = "+" + fmt2(popupDeltaDGB) + " DGB";

  // center text dynamically
  int16_t textWidth = reward.length() * 12; // approx width
  int textX = x + (w - textWidth) / 2;

  tft.setCursor(textX, y + 50);
  tft.print(reward);
}

void clearBlockPopup() {
  // Best-looking cleanup is to fully redraw the static scene, then redraw live values.
  // That avoids partial-image artifacts when the popup overlaps the image.
  drawStaticLayout();
}

bool fetchDgbBalance() {
  if (WiFi.status() != WL_CONNECTED || cfgWallet.isEmpty()) {
    statusText = cfgWallet.isEmpty() ? (String("SET WALLET ") + currentIpText()) : "BAL RETRY";
    // Keep last good wallet data on screen if we already have it.
    return false;
  }

  WiFiClientSecure client;
  client.setInsecure();
  HTTPClient http;
  http.setConnectTimeout(3000);
  http.setTimeout(4000);
  http.setUserAgent("ESP32-SOLO-HUNTER/1.0.1");

  if (!http.begin(client, chainzUrl())) {
    statusText = "BAL RETRY";
    return false;
  }

  int code = http.GET();
  if (code != 200) {
    statusText = "BAL HTTP " + String(code);
    http.end();
    return false;
  }

  String body = http.getString();
  http.end();
  body.trim();

  if (!body.length() || body.startsWith("ERROR")) {
    statusText = "BAL RETRY";
    return false;
  }

  balanceDGB = body.toFloat();
  haveWalletData = true;
  return true;
}

bool fetchDgbUsdPrice() {
  if (WiFi.status() != WL_CONNECTED) {
    statusText = haveWalletData ? "LIVE / USD WAIT" : "USD RETRY";
    return false;
  }

  WiFiClientSecure client;
  client.setInsecure();
  HTTPClient http;
  http.setConnectTimeout(2500);
  http.setTimeout(3500);
  http.setUserAgent("ESP32-SOLO-HUNTER/1.0.1");

  if (!http.begin(client, geckoUrl())) {
    statusText = haveWalletData ? "LIVE / USD WAIT" : "USD RETRY";
    return false;
  }

  int code = http.GET();
  if (code == 429) {
    statusText = "LIVE / USD WAIT";
    http.end();
    return false;
  }
  if (code != 200) {
    statusText = haveWalletData ? "LIVE / USD WAIT" : "USD HTTP " + String(code);
    http.end();
    return false;
  }

  String body = http.getString();
  http.end();

  int pos = body.indexOf("\"usd\":");
  if (pos < 0) {
    statusText = haveWalletData ? "LIVE / USD WAIT" : "USD PARSE FAIL";
    return false;
  }

  String sub = body.substring(pos + 6);
  int end = sub.indexOf("}");
  if (end > 0) sub = sub.substring(0, end);
  sub.trim();

  float newUsd = sub.toFloat();
  if (newUsd > 0.0f) {
    dgbPriceUsd = newUsd;
    haveUsdData = true;
    saveLastUsd();
    return true;
  }
  return false;
}

void refreshWalletOnly() {
  bool balOk = fetchDgbBalance();
  if (balOk) {
    statusText = "LIVE " + WiFi.localIP().toString();

    if (lastBalanceDGB < 0.0f) {
      lastBalanceDGB = balanceDGB;
      saveLastBalance();
    } else if (balanceDGB > lastBalanceDGB + 0.00001f) {
      deltaDGB = balanceDGB - lastBalanceDGB;
      popupDeltaDGB = deltaDGB;
      blockPopupLatched = true;
      popupActive = true;
      popupUntil = 0;
      savePopupState();
      lastBalanceDGB = balanceDGB;
      saveLastBalance();
    }
  } else if (haveWalletData) {
    statusText = "LIVE / BAL RETRY";
  }
}

void refreshUsdOnly() {
  if (!haveWalletData) return;
  bool usdOk = fetchDgbUsdPrice();
  if (usdOk) {
    statusText = "LIVE " + WiFi.localIP().toString();
  } else if (haveWalletData) {
    statusText = "LIVE / USD WAIT";
  }
}

