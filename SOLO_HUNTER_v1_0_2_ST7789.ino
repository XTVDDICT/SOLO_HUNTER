void handleSave() {
  if (server.hasArg("wallet")) cfgWallet = server.arg("wallet");
  cfgFlip = server.hasArg("flip");
  testPopupRequested = server.hasArg("testpop");
  trimConfig();
  savePrefs();
  applyRotation();
  drawStaticLayout();
  drawValues();

  if (testPopupRequested) {
    popupDeltaDGB = 0.00f;
    blockPopupLatched = false;
    popupActive = true;
    popupUntil = millis() + TEST_POPUP_MS;
    drawBlockPopup();
    // clear the request after using it once
    testPopupRequested = false;
    savePrefs();
  }

  server.send(200, "text/html",
    "<!doctype html><html><head>"
    "<meta http-equiv='refresh' content='2;url=/'>"
    "<meta name='viewport' content='width=device-width,initial-scale=1'>"
